<Window x:Class="AkangVoiceInput.App.FloatingStatusWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="620" Height="150" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" ShowActivated="False" Topmost="True" ResizeMode="NoResize">
    <Border Background="#F2FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="12" Padding="22"><Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
        <Border Width="38" Height="38" CornerRadius="9" Background="#DBEAFE" VerticalAlignment="Top"><TextBlock Text="●" Foreground="#2563EB" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
        <StackPanel Grid.Column="1" Margin="12,0,0,0">
            <TextBlock x:Name="TitleText" Text="正在聆听" FontSize="17" FontWeight="SemiBold"/>
            <ProgressBar x:Name="AudioLevel" Height="8" Maximum="1" Margin="0,10,0,8" Foreground="#2563EB"/>
            <TextBlock x:Name="PreviewText" Text="正在捕捉你的语音…" Foreground="#4B5563" TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="DetailText" Text="Ctrl + Alt + Space 停止" Foreground="#9CA3AF" FontSize="11" Margin="0,6,0,0"/>
        </StackPanel>
        <Button Grid.Column="2" Content="×" Width="28" Height="28" Padding="0" Margin="4,-6,-6,0"
                VerticalAlignment="Top" FontSize="18" Foreground="#6B7280" Background="Transparent"
                BorderThickness="0" ToolTip="关闭" Click="CloseClicked"/>
    </Grid></Border>
</Window>
